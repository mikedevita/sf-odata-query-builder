{
  "name": "sap-sfec-browser",
  "version": "1.0.0",
  "description": "SAP SuccessFactors EC OData Query Builder",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "vite build && electron-builder",
    "docker:build": "docker build -t sap-sfec-browser .",
    "docker:run": "docker run -p 3000:3000 sap-sfec-browser"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "express": "^4.19.0"
  },
  "build": {
    "appId": "co.devita.sap-sfec-browser",
    "productName": "SAP SFEC Browser",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
